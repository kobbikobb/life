# Ignore vault content — only track templates, structure, and docs
/*

# Folders to keep (empty scaffolding)
!goals/
!goals/.gitkeep
goals/*
!daily/
!daily/.gitkeep
daily/*
!todo/
!todo/.gitkeep
todo/*
!todo/archive/
!todo/archive/.gitkeep
todo/archive/*
!projects/
!projects/.gitkeep
projects/*
!notes/
!notes/.gitkeep
notes/*
!meetings/
!meetings/.gitkeep
meetings/*
!references/
!references/.gitkeep
references/*

# Templates, script, and docs
!/_templates/
!/_templates/**
!/scaffold.sh
!/next.sh
!README.md
!HOME.md
!LICENSE
!.gitignore
