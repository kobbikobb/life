# Ignore vault content — only track templates, structure, and docs
/*

# Folders to keep (empty scaffolding)
!goals/
!goals/.gitkeep
!daily/
!daily/.gitkeep
!todo/
!todo/.gitkeep
!todo/archive/
!todo/archive/.gitkeep
!projects/
!projects/.gitkeep
!notes/
!notes/.gitkeep
!references/
!references/.gitkeep
!references/*.md

# Templates, examples, and docs
!/_templates/
!/_templates/**
!/examples/
!/examples/**
!README.md
!HOME.md
!LICENSE
!.gitignore
